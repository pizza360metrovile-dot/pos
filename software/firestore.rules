rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // License Key Validation rules
    match /licenseKeys/{keyId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['isUsed', 'usedAt', 'usedByDeviceId', 'lastValidatedAt'])
                   && resource.data.isUsed == false;
    }

    // Default POS rules for restaurants
    match /restaurants/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
